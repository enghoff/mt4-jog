# Copy to .env (gitignored) and fill in. All variables are optional unless
# you enable public/OAuth mode. Loaded automatically by `python -m mt4_mcp`.

# --- Serial ---
# Omit MT4_SERIAL_PORT to auto-detect the CH340 USB-UART.
#MT4_SERIAL_PORT=COM6
#MT4_BAUD=115200

# --- Vision ---
# Omit to auto-detect the camera that sees the ArUco markers.
#MT4_CAMERA_INDEX=1

# --- MCP server (HTTP) ---
#MT4_MCP_HOST=127.0.0.1
#MT4_MCP_PORT=8787
#MT4_MCP_PATH=/mcp
# 1 = bind publicly (pair with ngrok + OAuth; see docs/OAUTH_CHATGPT.md)
#MT4_MCP_PUBLIC=0

# --- OAuth 2.1 for public access (docs/OAUTH_CHATGPT.md) ---
#MT4_OAUTH_ENABLED=1
# Must match the ngrok HTTPS origin exactly, no /mcp suffix.
#MT4_OAUTH_BASE_URL=https://your-name.ngrok-free.dev
#MT4_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
#MT4_GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx
# Optional: fixed JWT signing key; if unset, a random key is generated at
# startup and issued tokens are invalidated on every server restart.
#MT4_OAUTH_JWT_KEY=

# --- ngrok (scripts/start_ngrok.ps1) ---
# Your fixed *.ngrok-free.dev domain; keep equal to MT4_OAUTH_BASE_URL's host.
#MT4_NGROK_DOMAIN=your-name.ngrok-free.dev
